# ============================================================================
# FILE: .env.example
# PURPOSE: Environment variable template for Al Asly database and services
# USAGE: Copy to .env and fill in values for your Neon/deployment environment
# ============================================================================

# NEON POSTGRESQL DATABASE CONNECTION
# Get this from Neon Dashboard > Database > Connection string
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NEON PROJECT METADATA (optional, for dashboard)
NEON_PROJECT_ID=

# CLOUDINARY IMAGE STORAGE
# Get credentials from: https://cloudinary.com/console/settings/api-keys
CLOUDINARY_CLOUD_NAME=alasly
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT AUTHENTICATION
# Generate with: openssl rand -hex 32
JWT_SECRET=

# CLICK ERP SYNC WORKER CONFIGURATION
# How often the sync worker pulls updates from Click (in hours)
SYNC_INTERVAL_HOURS=6

# CLICK ERP DATABASE CONNECTION (read-only source)
# The sync worker uses these to read products every 6-12 hours
CLICK_DB_HOST=
CLICK_DB_PORT=5432
CLICK_DB_NAME=
CLICK_DB_USER=
CLICK_DB_PASSWORD=

# APPLICATION ENVIRONMENT
NODE_ENV=development
